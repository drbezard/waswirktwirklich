---
export const prerender = false;

import AuthLayout from '../../../layouts/AuthLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase/server';

const user = Astro.locals.user!;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

const statusFilter = Astro.url.searchParams.get('status') || 'all';

let query = supabase
  .from('revisions')
  .select(`
    id, article_slug, comment, status, admin_notes, created_at, resolved_at,
    doctor:doctor_id(id, full_name),
    article:articles(title, category)
  `)
  .order('created_at', { ascending: false })
  .limit(100);

if (statusFilter !== 'all') {
  query = query.eq('status', statusFilter);
}

const { data: revisions = [] } = await query;

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('de-DE', { day: 'numeric', month: 'short', year: 'numeric' });
}

const statusLabels = {
  open: { label: 'Offen', color: 'bg-amber-100 text-amber-800' },
  in_admin_review: { label: 'In Bearbeitung', color: 'bg-blue-100 text-blue-800' },
  resolved: { label: 'Erledigt', color: 'bg-green-100 text-green-800' },
  dismissed: { label: 'Abgelehnt', color: 'bg-gray-100 text-gray-800' },
};
---

<AuthLayout title="Revisionen" section="admin" user={user}>
  <div class="space-y-6">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <h1 class="text-2xl font-bold text-text">Revisionen</h1>
      <div class="flex gap-2 flex-wrap">
        <a href="/admin/revisionen" class={`px-3 py-1.5 rounded-lg text-sm ${statusFilter === 'all' ? 'bg-primary text-white' : 'bg-white border border-border'}`}>Alle</a>
        <a href="?status=open" class={`px-3 py-1.5 rounded-lg text-sm ${statusFilter === 'open' ? 'bg-primary text-white' : 'bg-white border border-border'}`}>Offen</a>
        <a href="?status=in_admin_review" class={`px-3 py-1.5 rounded-lg text-sm ${statusFilter === 'in_admin_review' ? 'bg-primary text-white' : 'bg-white border border-border'}`}>In Bearbeitung</a>
        <a href="?status=resolved" class={`px-3 py-1.5 rounded-lg text-sm ${statusFilter === 'resolved' ? 'bg-primary text-white' : 'bg-white border border-border'}`}>Erledigt</a>
      </div>
    </div>

    {(revisions?.length ?? 0) === 0 ? (
      <div class="bg-white rounded-2xl border border-border-light p-12 text-center text-text-muted">
        Keine Revisionen in dieser Ansicht.
      </div>
    ) : (
      <div class="space-y-3">
        {revisions!.map((r) => (
          <a
            href={`/admin/revisionen/${r.id}`}
            class="block bg-white rounded-xl border border-border-light p-4 hover:border-primary/40 transition-colors no-underline"
          >
            <div class="flex items-start justify-between gap-4 mb-2 flex-wrap">
              <div>
                <div class="font-semibold text-text">{(r as any).article?.title || r.article_slug}</div>
                <div class="text-xs text-text-muted mt-0.5">
                  {(r as any).article?.category} · gemeldet von {(r as any).doctor?.full_name || '-'} · {formatDate(r.created_at)}
                </div>
              </div>
              <span class={`text-xs font-semibold px-2 py-1 rounded-full ${statusLabels[r.status].color}`}>
                {statusLabels[r.status].label}
              </span>
            </div>
            <p class="text-sm text-text-secondary line-clamp-2">{r.comment}</p>
          </a>
        ))}
      </div>
    )}
  </div>
</AuthLayout>
