---
export const prerender = false;

import AuthLayout from '../../../layouts/AuthLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase/server';

const user = Astro.locals.user!;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

let errorMessage: string | null = null;
let createdId: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const title = String(form.get('title') || '').trim();
  const description = String(form.get('description') || '').trim();
  const tagsRaw = String(form.get('tags') || '').trim();
  const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean) : null;

  if (title.length < 5) {
    errorMessage = 'Titel zu kurz (mind. 5 Zeichen).';
  } else {
    const { data, error } = await supabase
      .from('topics')
      .insert({
        title,
        description: description || null,
        source: 'admin',
        type: 'new',
        status: 'discovered',
        suggested_tags: tags,
        submitted_by: user.id,
      })
      .select('id')
      .single();
    if (error) errorMessage = error.message;
    else createdId = data.id;
  }
}

// Tag-Vokabular für Vorschläge
const { data: vocabRow } = await supabase.from('settings').select('value').eq('key', 'tags_vocabulary').maybeSingle();
const vocabulary: string[] = Array.isArray(vocabRow?.value) ? vocabRow.value : [];
---

<AuthLayout title="Neues Thema" section="admin" user={user}>
  <div class="max-w-2xl space-y-6">
    <nav class="text-sm text-text-muted">
      <a href="/admin/topics" class="hover:text-primary no-underline">Themen</a>
      <span class="mx-2">/</span><span>Neu</span>
    </nav>

    <h1 class="text-2xl font-bold text-text">Neues Thema vorschlagen</h1>

    {errorMessage && <div class="p-3 rounded-lg bg-amber-50 border border-amber-200 text-sm text-amber-800">{errorMessage}</div>}
    {createdId && (
      <div class="p-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800">
        Topic angelegt — <a href={`/admin/topics/${createdId}`} class="underline">öffnen</a>
      </div>
    )}

    <form method="post" class="space-y-4 bg-white rounded-2xl border border-border-light p-6">
      <div>
        <label class="block text-sm font-medium text-text mb-1.5">Titel</label>
        <input type="text" name="title" required minlength="5" maxlength="200"
          class="w-full px-4 py-2.5 rounded-lg border border-border-light focus:outline-none focus:ring-2 focus:ring-primary/30" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text mb-1.5">Beschreibung (optional)</label>
        <textarea name="description" rows="3"
          placeholder="Worum geht es? Kontext für Manus."
          class="w-full px-4 py-2.5 rounded-lg border border-border-light focus:outline-none focus:ring-2 focus:ring-primary/30"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text mb-1.5">Tags (komma-getrennt, optional)</label>
        <input type="text" name="tags"
          placeholder="z.B. orthopaedie, knie, injektion"
          class="w-full px-4 py-2.5 rounded-lg border border-border-light focus:outline-none focus:ring-2 focus:ring-primary/30" />
        {vocabulary.length > 0 && (
          <p class="text-xs text-text-muted mt-1">Vokabular: {vocabulary.slice(0, 12).join(', ')}…</p>
        )}
      </div>
      <button type="submit" class="px-6 py-2.5 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark">
        Thema anlegen
      </button>
    </form>
  </div>
</AuthLayout>
