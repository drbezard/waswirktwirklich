---
export const prerender = false;

import AuthLayout from '../../layouts/AuthLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase/server';

const user = Astro.locals.user!;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

let errorMessage: string | null = null;
let successMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const article_slug = String(formData.get('article_slug') || '');
  const doctor_id = String(formData.get('doctor_id') || '');
  const free = formData.get('free') === 'true';

  if (!article_slug || !doctor_id) {
    errorMessage = 'Artikel und Arzt müssen ausgewählt sein.';
  } else {
    const { error } = await supabase.rpc('admin_assign_article', {
      p_article_slug: article_slug,
      p_doctor_id: doctor_id,
      p_free: free,
    });

    if (error) {
      errorMessage = `Fehler: ${error.message}`;
    } else {
      successMessage = 'Artikel zugewiesen.';
    }
  }
}

const [{ data: articleStates = [] }, { data: doctors = [] }] = await Promise.all([
  supabase.from('article_states').select('slug, title, category, state'),
  supabase.from('profiles').select('id, full_name, title').eq('role', 'doctor').is('disabled_at', null).order('full_name'),
]);

const assignableArticles = (articleStates || []).filter((a) => a.state === 'unverified' || a.state === 'expired');
---

<AuthLayout title="Zuweisungen" section="admin" user={user}>
  <div class="max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold text-text">Artikel zuweisen</h1>
    <p class="text-text-secondary">
      Weise einem Arzt gezielt einen Artikel zu. Optional kostenlos (ohne Verifizierungs-Gebühr).
    </p>

    {successMessage && <div class="p-4 rounded-xl bg-green-50 border border-green-200 text-sm text-green-800">{successMessage}</div>}
    {errorMessage && <div class="p-4 rounded-xl bg-amber-50 border border-amber-200 text-sm text-amber-800">{errorMessage}</div>}

    <form method="post" class="bg-white rounded-2xl border border-border-light p-6 space-y-4">
      <div>
        <label for="article_slug" class="block text-sm font-medium text-text mb-1.5">Artikel</label>
        <select id="article_slug" name="article_slug" required
          class="w-full px-4 py-2.5 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-primary/30">
          <option value="">— Bitte wählen —</option>
          {assignableArticles.map((a) => (
            <option value={a.slug}>
              {a.title} ({a.category}){a.state === 'expired' ? ' · abgelaufen' : ''}
            </option>
          ))}
        </select>
        {assignableArticles.length === 0 && (
          <p class="text-xs text-amber-700 mt-1">Keine zuweisbaren Artikel verfügbar.</p>
        )}
      </div>

      <div>
        <label for="doctor_id" class="block text-sm font-medium text-text mb-1.5">Arzt</label>
        <select id="doctor_id" name="doctor_id" required
          class="w-full px-4 py-2.5 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-primary/30">
          <option value="">— Bitte wählen —</option>
          {(doctors || []).map((d) => (
            <option value={d.id}>
              {d.full_name || '(ohne Name)'}{d.title ? ` — ${d.title}` : ''}
            </option>
          ))}
        </select>
      </div>

      <div>
        <label class="flex items-start gap-3 text-sm text-text">
          <input type="checkbox" name="free" value="true" class="mt-1 w-4 h-4 rounded border-border text-primary" checked />
          <span>
            <strong>Kostenlos zuweisen</strong> (keine Verifizierungs-Gebühr für den Arzt).
            Wenn abgewählt, muss der Arzt regulär bezahlen.
          </span>
        </label>
      </div>

      <button type="submit" class="px-6 py-2.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark">
        Artikel zuweisen
      </button>
    </form>
  </div>
</AuthLayout>
