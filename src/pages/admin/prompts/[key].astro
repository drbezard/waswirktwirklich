---
export const prerender = false;

import AuthLayout from '../../../layouts/AuthLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase/server';

const user = Astro.locals.user!;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const key = Astro.params.key!;

let flash: string | null = null;
let errorMessage: string | null = null;
let pendingPreview: { oldBody: string; newBody: string; diff: Array<{ kind: '+' | '-' | '='; line: string }> } | null = null;
let pendingSummary: string = '';

const { data: prompt } = await supabase
  .from('prompts')
  .select('*')
  .eq('key', key)
  .maybeSingle();

if (!prompt) return Astro.redirect('/admin/prompts');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') || '');
  const newBody = String(form.get('body') || '');
  const summary = String(form.get('diff_summary') || '').trim();

  if (action === 'preview') {
    if (newBody === prompt.body) {
      flash = 'Keine Änderungen.';
    } else {
      pendingPreview = {
        oldBody: prompt.body,
        newBody,
        diff: simpleDiff(prompt.body, newBody),
      };
      pendingSummary = summary;
    }
  } else if (action === 'save') {
    if (newBody === prompt.body) {
      flash = 'Keine Änderungen — nicht gespeichert.';
    } else if (newBody.trim().length < 50) {
      errorMessage = 'Body zu kurz (mind. 50 Zeichen).';
    } else {
      const newVersion = (prompt.version || 1) + 1;
      const { error } = await supabase
        .from('prompts')
        .update({
          body: newBody,
          version: newVersion,
          updated_by: user.id,
          updated_at: new Date().toISOString(),
        })
        .eq('key', key);
      if (error) {
        errorMessage = error.message;
      } else {
        // History-Trigger schreibt automatisch, aber summary müssen wir nachpflegen
        if (summary) {
          await supabase
            .from('prompt_history')
            .update({ diff_summary: summary })
            .eq('prompt_key', key)
            .eq('version', newVersion);
        }
        return Astro.redirect(`/admin/prompts/${key}?saved=1`);
      }
    }
  }
}

if (Astro.url.searchParams.get('saved') === '1' && !flash && !errorMessage) {
  flash = 'Gespeichert.';
}

// Aktuellster Body neu laden (falls gerade gespeichert)
const { data: current } = await supabase.from('prompts').select('*').eq('key', key).maybeSingle();
const displayBody = pendingPreview ? pendingPreview.newBody : (current?.body || '');

function simpleDiff(oldText: string, newText: string): Array<{ kind: '+' | '-' | '='; line: string }> {
  const oldLines = oldText.split('\n');
  const newLines = newText.split('\n');
  const oldSet = new Set(oldLines);
  const newSet = new Set(newLines);
  const out: Array<{ kind: '+' | '-' | '='; line: string }> = [];

  // Naive: Zeile-für-Zeile vergleichen, dann hinzugefügte/entfernte separat anzeigen
  const max = Math.max(oldLines.length, newLines.length);
  for (let i = 0; i < max; i++) {
    const oldLine = oldLines[i];
    const newLine = newLines[i];
    if (oldLine === newLine) {
      out.push({ kind: '=', line: oldLine ?? '' });
    } else {
      if (oldLine !== undefined && !newSet.has(oldLine)) out.push({ kind: '-', line: oldLine });
      if (newLine !== undefined && !oldSet.has(newLine)) out.push({ kind: '+', line: newLine });
      if (oldLine !== undefined && newSet.has(oldLine) && newLine !== oldLine) {
        // Zeile existiert in newSet — wahrscheinlich Verschiebung, als = behandeln
        out.push({ kind: '=', line: oldLine });
      }
    }
  }
  return out;
}
---

<AuthLayout title={prompt.title} section="admin" user={user}>
  <div class="max-w-4xl space-y-6">
    <nav class="text-sm text-text-muted">
      <a href="/admin/prompts" class="hover:text-primary no-underline">Prompts</a>
      <span class="mx-2">/</span><span>{prompt.title}</span>
    </nav>

    <div>
      <h1 class="text-2xl font-bold text-text mb-1">{prompt.title}</h1>
      <code class="text-xs text-text-muted">{prompt.key}</code>
      <span class="ml-3 text-sm text-text-muted">aktuell: v{current?.version || prompt.version} · {new Date((current?.updated_at) || prompt.updated_at).toLocaleString('de-DE')}</span>
      <span class="ml-3 text-sm"><a href={`/admin/prompts/${key}/history`} class="text-primary no-underline">Verlauf →</a></span>
    </div>

    {flash && <div class="p-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-900">{flash}</div>}
    {errorMessage && <div class="p-3 rounded-lg bg-amber-50 border border-amber-200 text-sm text-amber-800">{errorMessage}</div>}

    {pendingPreview ? (
      <form method="post" class="space-y-4 bg-white rounded-2xl border border-amber-200 p-6">
        <div class="flex items-center gap-2">
          <span class="text-xl">⚠</span>
          <h2 class="text-lg font-bold text-text">Änderung bestätigen</h2>
        </div>
        <p class="text-sm text-text-secondary">Du speicherst v{(current?.version || prompt.version) + 1}. Diff:</p>
        <pre class="text-xs bg-bg-subtle p-3 rounded overflow-x-auto max-h-96 overflow-y-auto leading-relaxed">{
          pendingPreview.diff.map(d =>
            d.kind === '+' ? `+ ${d.line}\n`
            : d.kind === '-' ? `- ${d.line}\n`
            : `  ${d.line}\n`
          ).join('')
        }</pre>

        <input type="hidden" name="body" value={pendingPreview.newBody} />
        <input type="hidden" name="diff_summary" value={pendingSummary} />

        <div class="flex gap-2">
          <button type="submit" name="action" value="save"
            class="px-5 py-2.5 bg-green-600 text-white rounded-lg font-medium hover:bg-green-700">
            Bestätigen + Speichern
          </button>
          <a href={`/admin/prompts/${key}`} class="px-5 py-2.5 border border-border-light text-text rounded-lg hover:bg-bg-subtle no-underline">
            Abbrechen
          </a>
        </div>
      </form>
    ) : (
      <form method="post" class="space-y-4">
        <textarea name="body" rows="24" required
          class="w-full px-4 py-3 rounded-lg border border-border-light text-sm font-mono leading-relaxed focus:outline-none focus:ring-2 focus:ring-primary/30">{displayBody}</textarea>

        <input type="text" name="diff_summary" placeholder="Kurze Zusammenfassung der Änderung (optional, geht ins Audit-Log)"
          class="w-full px-3 py-2 rounded border border-border-light text-sm" />

        <div class="flex gap-2">
          <button type="submit" name="action" value="preview"
            class="px-5 py-2.5 bg-primary text-white rounded-lg font-medium hover:bg-primary-dark">
            Diff-Vorschau
          </button>
          <a href={`/admin/prompts`} class="px-5 py-2.5 border border-border-light text-text rounded-lg hover:bg-bg-subtle no-underline">
            Zurück
          </a>
        </div>
      </form>
    )}

    {prompt.description && (
      <div class="bg-bg-subtle rounded-xl p-4 text-sm text-text-secondary">
        <strong class="text-text">Was dieser Prompt tut:</strong> {prompt.description}
      </div>
    )}
  </div>
</AuthLayout>
