---
export const prerender = false;

import AuthLayout from '../../../../layouts/AuthLayout.astro';
import { createSupabaseServerClient } from '../../../../lib/supabase/server';

const user = Astro.locals.user!;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const key = Astro.params.key!;

const { data: prompt } = await supabase
  .from('prompts')
  .select('key, title')
  .eq('key', key)
  .maybeSingle();

if (!prompt) return Astro.redirect('/admin/prompts');

const { data: history = [] } = await supabase
  .from('prompt_history')
  .select('id, version, body, changed_at, diff_summary, changed_by:profiles(full_name)')
  .eq('prompt_key', key)
  .order('changed_at', { ascending: false })
  .limit(100);
---

<AuthLayout title={`Verlauf: ${prompt.title}`} section="admin" user={user}>
  <div class="max-w-4xl space-y-6">
    <nav class="text-sm text-text-muted">
      <a href="/admin/prompts" class="hover:text-primary no-underline">Prompts</a>
      <span class="mx-2">/</span>
      <a href={`/admin/prompts/${key}`} class="hover:text-primary no-underline">{prompt.title}</a>
      <span class="mx-2">/</span><span>Verlauf</span>
    </nav>

    <h1 class="text-2xl font-bold text-text">Verlauf: {prompt.title}</h1>

    {!history || history.length === 0 ? (
      <div class="bg-white rounded-2xl border border-border-light p-12 text-center text-text-muted">
        Noch keine Versionen.
      </div>
    ) : (
      <div class="space-y-3">
        {history.map((h: any) => (
          <details class="bg-white rounded-2xl border border-border-light">
            <summary class="cursor-pointer p-4 flex items-center justify-between">
              <div>
                <div class="font-semibold text-text">v{h.version}</div>
                <div class="text-xs text-text-muted">
                  {new Date(h.changed_at).toLocaleString('de-DE')}
                  {h.changed_by?.full_name && <span> · von {h.changed_by.full_name}</span>}
                </div>
                {h.diff_summary && <div class="text-sm text-text-secondary mt-1">{h.diff_summary}</div>}
              </div>
              <span class="text-xs text-text-muted">{h.body.length} Zeichen</span>
            </summary>
            <pre class="text-xs p-4 border-t border-border-light bg-bg-subtle whitespace-pre-wrap font-mono max-h-96 overflow-y-auto">{h.body}</pre>
          </details>
        ))}
      </div>
    )}
  </div>
</AuthLayout>
