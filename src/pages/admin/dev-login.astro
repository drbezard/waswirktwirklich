---
/**
 * Notfall-Login ohne E-Mail.
 *
 * Erzeugt einen Magic-Link über den Service-Role-Key direkt im Browser
 * (ohne dass eine Mail versendet wird). Schutz: ein geheimer Wert, der
 * als Environment Variable DEV_LOGIN_SECRET hinterlegt ist.
 *
 * Diese Seite kann später entfernt werden, wenn Resend eingerichtet ist.
 * Bis dahin: nur du kennst das Secret, also nur du kannst rein.
 */

export const prerender = false;

import AuthLayout from '../../layouts/AuthLayout.astro';
import { getSupabaseAdminClient } from '../../lib/supabase/admin';

let errorMessage: string | null = null;
let magicLinkUrl: string | null = null;
let warningMessage: string | null = null;

const expectedSecret = import.meta.env.DEV_LOGIN_SECRET;

if (!expectedSecret) {
  errorMessage = 'DEV_LOGIN_SECRET ist nicht gesetzt. Trage die Variable in Vercel ein.';
}

if (Astro.request.method === 'POST' && expectedSecret) {
  try {
    const formData = await Astro.request.formData();
    const email = String(formData.get('email') || '').trim().toLowerCase();
    const secret = String(formData.get('secret') || '').trim();

    if (secret !== expectedSecret) {
      errorMessage = 'Falsches Secret.';
    } else if (!email || !email.includes('@')) {
      errorMessage = 'Bitte gib eine gültige E-Mail-Adresse ein.';
    } else {
      const admin = getSupabaseAdminClient();
      const redirectTo = `${Astro.url.origin}/auth/callback?next=/admin`;

      const { data, error } = await admin.auth.admin.generateLink({
        type: 'magiclink',
        email,
        options: { redirectTo },
      });

      if (error) {
        errorMessage = `Fehler: ${error.message}`;
      } else if (data?.properties?.action_link) {
        magicLinkUrl = data.properties.action_link;
        warningMessage = 'Login-Link erzeugt. Klicke unten — ist nur einmal verwendbar und gilt 1 Stunde.';
      } else {
        errorMessage = 'Kein Link zurückgekommen.';
      }
    }
  } catch (err) {
    errorMessage = `Unerwarteter Fehler: ${err instanceof Error ? err.message : String(err)}`;
  }
}
---

<AuthLayout title="Notfall-Login" section="admin">
  <div class="max-w-md mx-auto pt-8">
    <div class="bg-white rounded-2xl border border-border shadow-sm p-8">
      <h1 class="text-2xl font-bold text-text mb-2">Notfall-Login</h1>
      <p class="text-sm text-text-secondary mb-6">
        Direkter Magic-Link, falls die E-Mail-Zustellung blockiert ist.
        Nach Resend-Setup kann diese Seite entfernt werden.
      </p>

      {errorMessage && (
        <div class="mb-6 p-4 rounded-xl bg-amber-50 border border-amber-200 text-sm text-amber-800">
          {errorMessage}
        </div>
      )}

      {warningMessage && (
        <div class="mb-6 p-4 rounded-xl bg-green-50 border border-green-200 text-sm text-green-800">
          {warningMessage}
        </div>
      )}

      {magicLinkUrl ? (
        <div class="space-y-4">
          <a
            href={magicLinkUrl}
            class="block w-full px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark text-center no-underline"
          >
            → Jetzt einloggen
          </a>
          <details class="text-xs text-text-muted">
            <summary class="cursor-pointer">Link anzeigen</summary>
            <code class="block mt-2 p-2 bg-bg-subtle rounded break-all text-[10px]">{magicLinkUrl}</code>
          </details>
          <a href="/admin/dev-login" class="block text-center text-xs text-text-muted hover:text-primary">
            Neuer Link
          </a>
        </div>
      ) : (
        <form method="post" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-text mb-1.5">E-Mail</label>
            <input
              type="email" id="email" name="email" required autocomplete="email" autofocus
              class="w-full px-4 py-2.5 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-primary/30"
            />
          </div>

          <div>
            <label for="secret" class="block text-sm font-medium text-text mb-1.5">Secret</label>
            <input
              type="password" id="secret" name="secret" required
              placeholder="DEV_LOGIN_SECRET aus Vercel"
              class="w-full px-4 py-2.5 rounded-lg border border-border focus:outline-none focus:ring-2 focus:ring-primary/30"
            />
          </div>

          <button
            type="submit"
            class="w-full px-6 py-2.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark"
          >
            Login-Link erzeugen
          </button>
        </form>
      )}
    </div>
  </div>
</AuthLayout>
