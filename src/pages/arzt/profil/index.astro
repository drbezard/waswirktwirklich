---
export const prerender = false;

import AuthLayout from '../../../layouts/AuthLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase/server';

const user = Astro.locals.user!;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

let errorMessage: string | null = null;
let successMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const full_name = String(formData.get('full_name') || '').trim();
  const title = String(formData.get('title') || '').trim();
  const bio = String(formData.get('bio') || '').trim();
  const website_url = String(formData.get('website_url') || '').trim();
  const photo_url = String(formData.get('photo_url') || '').trim();

  if (website_url && !/^https?:\/\//.test(website_url)) {
    errorMessage = 'Webseite muss mit http:// oder https:// beginnen.';
  } else {
    const { error } = await supabase
      .from('profiles')
      .update({
        full_name: full_name || null,
        title: title || null,
        bio: bio || null,
        website_url: website_url || null,
        photo_url: photo_url || null,
      })
      .eq('id', user.id);

    if (error) {
      errorMessage = `Speichern fehlgeschlagen: ${error.message}`;
    } else {
      successMessage = 'Profil gespeichert.';
    }
  }
}

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();

// Statistiken
const [{ count: verifiedCount }, { count: revisedCount }] = await Promise.all([
  supabase
    .from('verifications')
    .select('*', { count: 'exact', head: true })
    .eq('doctor_id', user.id)
    .is('revoked_at', null),
  supabase
    .from('revisions')
    .select('*', { count: 'exact', head: true })
    .eq('doctor_id', user.id),
]);
---

<AuthLayout title="Mein Profil" section="arzt" user={user}>
  <div class="max-w-2xl mx-auto space-y-6">
    <h1 class="text-2xl font-bold text-text">Mein Profil</h1>

    {successMessage && (
      <div class="p-4 rounded-xl bg-green-50 border border-green-200 text-sm text-green-800">
        {successMessage}
      </div>
    )}
    {errorMessage && (
      <div class="p-4 rounded-xl bg-amber-50 border border-amber-200 text-sm text-amber-800">
        {errorMessage}
      </div>
    )}

    <div class="bg-white rounded-2xl border border-border-light p-6">
      <div class="grid grid-cols-2 gap-4 mb-6">
        <div>
          <div class="text-xs text-text-muted">Verifizierte Artikel</div>
          <div class="text-2xl font-bold text-text">{verifiedCount ?? 0}</div>
        </div>
        <div>
          <div class="text-xs text-text-muted">Revisionen gemeldet</div>
          <div class="text-2xl font-bold text-text">{revisedCount ?? 0}</div>
        </div>
      </div>

      <form method="post" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1.5">E-Mail (nicht änderbar)</label>
          <input
            type="email"
            value={user.email}
            disabled
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-bg-subtle text-text-muted"
          />
        </div>

        <div>
          <label for="full_name" class="block text-sm font-medium text-text mb-1.5">Voller Name *</label>
          <input
            type="text"
            id="full_name"
            name="full_name"
            value={profile?.full_name || ''}
            required
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
          />
        </div>

        <div>
          <label for="title" class="block text-sm font-medium text-text mb-1.5">Fachbezeichnung</label>
          <input
            type="text"
            id="title"
            name="title"
            value={profile?.title || ''}
            placeholder="z.B. Facharzt für Orthopädie · Wien"
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
          />
        </div>

        <div>
          <label for="bio" class="block text-sm font-medium text-text mb-1.5">Kurzbeschreibung</label>
          <textarea
            id="bio"
            name="bio"
            rows="3"
            placeholder="Kurze fachliche Biografie, die in deinem Prüfer-Kasten erscheint"
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
          >{profile?.bio || ''}</textarea>
        </div>

        <div>
          <label for="website_url" class="block text-sm font-medium text-text mb-1.5">Webseite (optional)</label>
          <input
            type="url"
            id="website_url"
            name="website_url"
            value={profile?.website_url || ''}
            placeholder="https://…"
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
          />
        </div>

        <div>
          <label for="photo_url" class="block text-sm font-medium text-text mb-1.5">Profilfoto-URL (optional)</label>
          <input
            type="url"
            id="photo_url"
            name="photo_url"
            value={profile?.photo_url || ''}
            placeholder="https://…"
            class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary"
          />
          <p class="text-xs text-text-muted mt-1">Direkter Link zu einem Foto (JPG/PNG). Upload folgt später.</p>
        </div>

        <button type="submit" class="px-6 py-2.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-colors">
          Profil speichern
        </button>
      </form>
    </div>
  </div>
</AuthLayout>
