---
import Base from '../layouts/Base.astro';
---

<Base title="Seite nicht gefunden" description="Die angeforderte Seite existiert nicht.">
  <section class="py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-5 text-center">
      <span class="text-7xl font-bold text-primary/20 block mb-4">404</span>
      <h1 class="text-2xl md:text-3xl font-bold text-text mb-4">Seite nicht gefunden</h1>
      <p class="text-text-secondary mb-8 max-w-md mx-auto">
        Die angeforderte Seite existiert nicht oder wurde verschoben.
      </p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white font-semibold hover:bg-primary-dark transition-colors no-underline">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Zur Startseite
      </a>
    </div>
  </section>
</Base>
