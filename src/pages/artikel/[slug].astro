---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('artikel');
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const formattedDate = new Date(article.data.date).toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Estimate reading time (~200 words/min German)
const wordCount = article.body ? article.body.split(/\s+/).length : 0;
const readingTime = Math.max(5, Math.ceil(wordCount / 200));

// Category slug helper
const catSlug = article.data.category.toLowerCase()
  .replace(/\s+/g, '-')
  .replace(/ä/g,'ae').replace(/ö/g,'oe').replace(/ü/g,'ue');
---

<Base
  title={article.data.seoTitle || article.data.title}
  description={article.data.seoDescription || article.data.excerpt}
  image={article.data.image}
>
  <article>
    <!-- Hero Image -->
    {article.data.image && (
      <div class="w-full max-w-4xl mx-auto px-5 pt-8 md:pt-12">
        <img
          src={article.data.image}
          alt={article.data.title}
          class="w-full h-auto rounded-2xl object-cover shadow-sm"
          loading="eager"
        />
      </div>
    )}

    <div class="article-bg">
    <div class="max-w-3xl mx-auto px-5 pt-8 pb-16">
      <!-- Category Badge -->
      <div class="text-center mb-4">
        <a href={`/fachgebiet/${catSlug}`}
           class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary font-semibold text-xs uppercase tracking-wider no-underline hover:bg-primary/20 transition-colors">
          {article.data.category}
        </a>
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-[2.5rem] font-bold text-text leading-tight text-center mb-6">
        {article.data.title}
      </h1>

      <!-- Meta Line -->
      <p class="text-center text-sm text-text-muted mb-8">
        Zuletzt aktualisiert: {formattedDate} · Lesezeit: ca. {readingTime} Minuten · Evidenzcheck: Geprüft anhand aktueller Meta-Analysen und Leitlinien
      </p>

      <!-- Reviewer Box (reviewed articles) -->
      {article.data.reviewed && article.data.reviewer && (
        <div class="mb-10 p-5 md:p-6 rounded-2xl border border-border-light bg-white shadow-sm">
          <div class="flex items-start gap-4">
            {article.data.reviewerPhoto && (
              <img
                src={article.data.reviewerPhoto}
                alt={article.data.reviewer}
                class="w-16 h-16 rounded-full object-cover flex-shrink-0"
              />
            )}
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="font-semibold text-text">{article.data.reviewer}</span>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-50 text-green-700 text-xs font-medium">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Geprüft
                </span>
              </div>
              {article.data.reviewerTitle && (
                <p class="text-sm text-primary mb-2">{article.data.reviewerTitle}</p>
              )}
              {article.data.reviewerUrl && (
                <a href={article.data.reviewerUrl} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-dark no-underline transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  {new URL(article.data.reviewerUrl!).hostname.replace('www.', '')}
                </a>
              )}
            </div>
          </div>
        </div>
      )}

      <!-- Pending Review Box (unreviewed articles) -->
      {!article.data.reviewed && (
        <div class="mb-10 flex items-center gap-3 p-4 rounded-xl border border-amber-200 bg-amber-50/50">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <span class="text-sm font-medium text-amber-800">Ausstehend – wartet auf Arzt-Review</span>
            <p class="text-xs text-amber-600 mt-0.5">Dieser Artikel wurde noch nicht von einem Facharzt geprüft.</p>
          </div>
        </div>
      )}

      <!-- Die Kernaussage kommt jetzt aus dem Markdown-Inhalt mit class="kernaussage" -->

      <!-- Artikel-Inhalt -->
      <div class="article-content prose prose-gray max-w-none
        prose-headings:text-text prose-headings:font-bold
        prose-h2:text-[1.6rem] prose-h2:mt-12 prose-h2:mb-5 prose-h2:leading-snug
        prose-h3:text-xl prose-h3:mt-9 prose-h3:mb-3 prose-h3:font-semibold
        prose-p:text-text-secondary prose-p:leading-[1.8] prose-p:text-[1.05rem] prose-p:mb-5
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-text prose-strong:font-semibold
        prose-li:text-text-secondary prose-li:leading-[1.8] prose-li:text-[1.05rem]
        prose-blockquote:border-primary prose-blockquote:bg-sky-50/50 prose-blockquote:rounded-r-xl prose-blockquote:py-2 prose-blockquote:px-5 prose-blockquote:text-text-secondary prose-blockquote:not-italic
        prose-table:text-sm
        prose-th:text-text prose-th:font-semibold prose-th:bg-gray-50 prose-th:p-3
        prose-td:text-text-secondary prose-td:p-3
        prose-img:rounded-xl prose-img:shadow-sm
      ">
        <Content />
      </div>

      <!-- KI-Prompt (wenn vorhanden) -->
      {article.data.prompt && (
        <details class="mt-14 border border-border-light rounded-2xl overflow-hidden">
          <summary class="px-6 py-4 bg-bg-subtle cursor-pointer text-sm font-medium text-text hover:bg-gray-100 transition-colors">
            KI-Prompt anzeigen (Transparenz)
          </summary>
          <div class="px-6 py-5 text-sm text-text-secondary bg-white whitespace-pre-wrap font-mono leading-relaxed">
            {article.data.prompt}
          </div>
        </details>
      )}

      <!-- Quellen (wenn vorhanden) -->
      {article.data.sources && article.data.sources.length > 0 && (
        <div class="mt-12 border-t border-border-light pt-8">
          <h2 class="text-lg font-bold text-text mb-4">Quellen</h2>
          <ol class="space-y-2 text-sm text-text-secondary list-decimal list-inside">
            {article.data.sources.map((source: string) => (
              <li class="leading-relaxed">{source}</li>
            ))}
          </ol>
        </div>
      )}

      <!-- Zurück -->
      <div class="mt-14 pt-8 border-t border-border-light">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-primary-dark transition-colors no-underline">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Zurück zur Übersicht
        </a>
      </div>
    </div>
    </div>
  </article>
</Base>
